// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELO UNIFICADO ---
model Link {
  id        Int      @id @default(autoincrement())
  original  String   // A URL original
  shortCode String   @unique // O código curto
  createdAt DateTime @default(now())
  
  // Relacionamento: Um link tem vários logs de analytics
  analytics Analytics[] 

  @@map("links") // Mantém o nome da tabela como "links"
}

model Analytics {
  id        Int      @id @default(autoincrement())
  clickedAt DateTime @default(now())
  ip        String?
  userAgent String?
  
  // Chave estrangeira (Foreign Key)
  linkId    Int
  link      Link     @relation(fields: [linkId], references: [id])
}